end;

procedure TViewPrincipal.GET_LineMenu(Sender: TObject);
begin
  ShapeMenu.Visible := True;
  ShapeMenu.Left := 0;
  ShapeMenu.Top := 0;
  ShapeMenu.Height := TSpeedButton(Sender).Height;
  ShapeMenu.Top := TSpeedButton(Sender).Top;
  pnlShapeMenu.Repaint;
end;

